# App mode
APP_MODE=mock

# Frontend -> FastAPI backend URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# FastAPI CORS allowlist (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000

# GitHub webhook secret for POST /api/webhooks/pr signature verification
GITHUB_WEBHOOK_SECRET=replace_with_webhook_secret

# Proof signature key (required for verifiable proof packs in production)
PROOF_SIGNING_KEY=replace_with_strong_random_value

# SafeDep (real mode)
SAFEDEP_CLOUD_TENANT_DOMAIN=replace_with_safedep_tenant
SAFEDEP_CLOUD_API_KEY=replace_with_safedep_api_key

# Unsiloed (optional policy parsing)
UNSILOED_API_KEY=replace_with_unsiloed_api_key

# MCP integration toggles
GITHUB_MCP_ENABLED=false
SLACK_MCP_ENABLED=false
JIRA_MCP_ENABLED=false
LINEAR_MCP_ENABLED=false

# Exception routing target: jira | linear | none
EXCEPTION_PROVIDER=none

# AWS free-tier target resources (optional)
AWS_REGION=us-east-1
ARTIFACT_BUCKET=
DYNAMODB_TABLE=
SNS_TOPIC_ARN=
